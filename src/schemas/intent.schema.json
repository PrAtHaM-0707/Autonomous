{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "intent-schema-v1",
  "title": "Intent Plan Schema",
  "description": "Structured intent model for ArmorClaw policy enforcement",
  "type": "object",
  "required": ["id", "timestamp", "userPrompt", "goal", "agentRole", "steps"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this intent plan",
      "pattern": "^intent-[a-f0-9-]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When this intent was created"
    },
    "userPrompt": {
      "type": "string",
      "description": "Original user request that generated this intent"
    },
    "goal": {
      "type": "string",
      "description": "High-level goal derived from user prompt"
    },
    "agentRole": {
      "type": "string",
      "enum": ["lead-agent", "refactor-agent", "review-agent"],
      "description": "Role of the agent executing this intent"
    },
    "delegatedFrom": {
      "type": "string",
      "description": "If delegated, the agent that delegated this task"
    },
    "delegationScope": {
      "type": "object",
      "description": "Scope restrictions if this is a delegated task",
      "properties": {
        "allowedPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowedActions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validUntil": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "steps": {
      "type": "array",
      "description": "Ordered list of actions to execute",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stepId", "action", "target", "purpose"],
        "properties": {
          "stepId": {
            "type": "integer",
            "minimum": 1,
            "description": "Sequential step identifier"
          },
          "action": {
            "type": "string",
            "enum": ["read_file", "write_file", "list_dir", "delete_file", "bash", "exec", "web_fetch", "web_search", "delegate"],
            "description": "The tool/action to execute"
          },
          "target": {
            "type": "object",
            "required": ["type", "path"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["file", "directory", "url", "command"]
              },
              "path": {
                "type": "string",
                "description": "Target resource path"
              }
            }
          },
          "purpose": {
            "type": "string",
            "description": "Human-readable explanation of why this step is needed"
          },
          "content": {
            "type": "string",
            "description": "Content to write (for write operations)"
          },
          "requiredPermissions": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of permissions needed for this step"
          }
        }
      }
    }
  }
}
